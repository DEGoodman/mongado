# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Security settings (set to True in production)
SECURE_SSL_REDIRECT=False  # Set to True in production to force HTTPS
SESSION_COOKIE_SECURE=False  # Set to True in production to ensure cookies are only sent over HTTPS
CSRF_COOKIE_SECURE=False  # Set to True in production to ensure CSRF cookies are only sent over HTTPS
SECURE_BROWSER_XSS_FILTER=False  # Set to True in production to enable XSS filtering
SECURE_CONTENT_TYPE_NOSNIFF=False  # Set to True in production to prevent MIME type sniffing
X_FRAME_OPTIONS=SAMEORIGIN  # Set to 'DENY' in production to prevent clickjacking

# Database settings (use SQLite by default)
# Uncomment the line below to use PostgreSQL
# DATABASE_URL=postgres://user:password@localhost:5432/mongado